# Rust build artifacts
**/target/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Environment & Secrets
.env
.env.*
!.env.example
*.pem
*.key
*.secret

# Network topology (contains real IPs, MACs, credentials)
yggdrasil/docs/NetworkHardware.md

# Real config files (use *.example as templates)
yggdrasil/configs/*/config.json
yggdrasil/configs/*/config.local.json
yggdrasil/configs/*/config.yaml
yggdrasil/configs/*/node.yaml
yggdrasil/configs/ha/*.yaml
!yggdrasil/configs/*/config.example.json

# Systemd units with credentials (use templates)
yggdrasil/deploy/systemd/*.service
!yggdrasil/deploy/systemd/*.service.example

# Workstation local config
yggdrasil/deploy/workstation/local-config.yaml
!yggdrasil/deploy/workstation/local-config.example.yaml

# Sprint files (ephemeral, archived to memory)
yggdrasil/sprints/

# Claude local instructions
yggdrasil/.claude/
yggdrasil/deploy/workstation/CLAUDE.md

# QA reports (may contain sensitive references)
qareports/

# Misc notes
noteforuser.md

# Claude Code local config (per-workstation, may contain IPs)
.claude/
.mcp.json

# Python bytecode
__pycache__/

# Training data (contains real IPs, usernames, topology from engrams)
yggdrasil/training/saga/data/

# Temporary files
/tmp/
*.tmp
*.bak
NEXT_STEPS.md
random_thought.txt
yggdrasil/deploy/munin/vision-server/server.py
yggdrasil/deploy/munin/vision-server/yggdrasil-vision.service
