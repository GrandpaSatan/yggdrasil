# Yggdrasil Environment Variables
# Copy this file to .env and fill in your values.
# These are referenced by config files via ${VAR_NAME} syntax.

# =============================================================================
# Database (PostgreSQL with pgvector)
# =============================================================================
# Connection URL for Mimir (engram memory service)
MIMIR_DATABASE_URL=postgres://yggdrasil:changeme@localhost:5432/yggdrasil

# Connection URL for Huginn (code indexer)
HUGINN_DATABASE_URL=postgres://yggdrasil:changeme@localhost:5432/yggdrasil

# Connection URL for Muninn (code retrieval)
MUNINN_DATABASE_URL=postgres://yggdrasil:changeme@localhost:5432/yggdrasil

# Connection URL for MCP remote server (migrations)
MCP_DATABASE_URL=postgres://yggdrasil:changeme@localhost:5432/yggdrasil

# =============================================================================
# Home Assistant
# =============================================================================
# Long-lived access token from HA (Settings > Security > Long-lived tokens)
HA_TOKEN=

# =============================================================================
# Cloud Provider Fallback (optional)
# =============================================================================
# API keys for cloud LLM fallback when local backends are saturated
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# =============================================================================
# Gitea Integration (optional, for ygg-agent and gitea-sync)
# =============================================================================
GITEA_URL=http://localhost:3000
GITEA_TOKEN=

# =============================================================================
# ONNX Runtime
# =============================================================================
# Path to the ONNX Runtime shared library
ORT_DYLIB_PATH=/opt/yggdrasil/lib/libonnxruntime.so

# =============================================================================
# Node IPs (used by config files and deploy scripts)
# =============================================================================
# Set these to the IP addresses of each node in your deployment.
MUNIN_IP=
HUGIN_IP=
HADES_IP=
THOR_IP=
CHIRP_IP=
GITEA_IP=
NIGHTJAR_IP=
WOL_BROADCAST=

# =============================================================================
# Deployment (used by deploy scripts)
# =============================================================================
# SSH user for deploy scripts (default: yggdrasil)
# DEPLOY_USER=yggdrasil
