{
  "node": {
    "name": "hugin",
    "role": "compute-agent",
    "services": ["huginn", "muninn", "ygg-node"],
    "advertise_addr": "${HUGIN_IP}",
    "mesh_port": 9100
  },
  "discovery": {
    "mode": "mdns",
    "seeds": [
      { "name": "munin", "addr": "${MUNIN_IP}", "port": 9100 }
    ],
    "mdns_service": "_yggdrasil._tcp.local"
  },
  "heartbeat": {
    "interval_secs": 30,
    "missed_threshold": 3
  },
  "gate": {
    "default_policy": "allow",
    "rules": []
  }
}
