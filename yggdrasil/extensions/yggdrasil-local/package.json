{
  "name": "yggdrasil-local",
  "displayName": "Yggdrasil Local",
  "description": "Local Yggdrasil interface — memory monitor + dashboard",
  "version": "0.1.0",
  "publisher": "yggdrasil",
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "yggdrasil.openDashboard",
        "title": "Yggdrasil: Open Memory Dashboard"
      },
      {
        "command": "yggdrasil.showLog",
        "title": "Yggdrasil: Show Memory Log"
      },
      {
        "command": "yggdrasil.toggleNotifications",
        "title": "Yggdrasil: Toggle Notifications"
      }
    ],
    "keybindings": [
      {
        "command": "yggdrasil.openDashboard",
        "key": "ctrl+shift+m",
        "when": "!terminalFocus"
      }
    ],
    "configuration": {
      "title": "Yggdrasil Local",
      "properties": {
        "yggdrasil.eventsFile": {
          "type": "string",
          "default": "/tmp/ygg-hooks/memory-events.jsonl",
          "description": "Path to the JSONL event file written by ygg-memory.sh hooks"
        },
        "yggdrasil.notifications.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show toast notifications for memory operations"
        },
        "yggdrasil.notifications.sound": {
          "type": "boolean",
          "default": false,
          "description": "Play audio cue on memory store"
        },
        "yggdrasil.notifications.events": {
          "type": "array",
          "default": ["ingest", "error"],
          "items": {
            "type": "string",
            "enum": ["init", "recall", "ingest", "sleep", "error"]
          },
          "description": "Which event types trigger notifications"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "package": "npx @vscode/vsce package --no-dependencies"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0"
  }
}
