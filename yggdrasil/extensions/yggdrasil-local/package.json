{
  "name": "yggdrasil-local",
  "displayName": "Yggdrasil",
  "description": "Control panel for the Yggdrasil local-AI ecosystem — flows, memory, config, chat.",
  "version": "0.11.0",
  "publisher": "yggdrasil",
  "license": "MIT",
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#09090b",
    "theme": "dark"
  },
  "homepage": "https://github.com/GrandpaSatan/Yggdrasil",
  "repository": {
    "type": "git",
    "url": "https://github.com/GrandpaSatan/Yggdrasil.git"
  },
  "bugs": {
    "url": "https://github.com/GrandpaSatan/Yggdrasil/issues"
  },
  "qna": "marketplace",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Machine Learning",
    "Other"
  ],
  "keywords": [
    "ai",
    "llm",
    "ollama",
    "local-ai",
    "homelab",
    "chat",
    "coding-agent",
    "rag",
    "mcp",
    "yggdrasil"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "yggdrasil",
          "title": "Yggdrasil",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "yggdrasil": [
        {
          "id": "yggdrasil.flowsTree",
          "name": "Flows",
          "icon": "media/icon.svg",
          "contextualTitle": "Yggdrasil Flows"
        },
        {
          "id": "yggdrasil.modelsTree",
          "name": "Models",
          "contextualTitle": "Yggdrasil Models"
        },
        {
          "id": "yggdrasil.repo",
          "name": "Workspace Files",
          "contextualTitle": "Yggdrasil Repo"
        }
      ]
    },
    "walkthroughs": [
      {
        "id": "yggdrasil.welcome",
        "title": "Get Started with Yggdrasil",
        "description": "Connect to your Yggdrasil server and open your first chat",
        "steps": [
          {
            "id": "welcome",
            "title": "What is Yggdrasil?",
            "description": "A self-hosted local-AI ecosystem with a router, memory, and chat client.",
            "media": {
              "markdown": "media/walkthrough/welcome.md"
            }
          },
          {
            "id": "configure-odin",
            "title": "Configure Odin (the router)",
            "description": "Tell the extension where to find your Odin server.",
            "media": {
              "markdown": "media/walkthrough/configure-odin.md"
            },
            "completionEvents": [
              "onCommand:yggdrasil.openSettings"
            ]
          },
          {
            "id": "configure-mimir",
            "title": "Configure Mimir (memory, optional)",
            "description": "Connect the engram memory service for /memory recall.",
            "media": {
              "markdown": "media/walkthrough/configure-mimir.md"
            }
          },
          {
            "id": "explore-flows",
            "title": "Explore the Flows",
            "description": "See how multi-model pipelines like coding_swarm work.",
            "media": {
              "markdown": "media/walkthrough/explore-flows.md"
            },
            "completionEvents": [
              "onCommand:yggdrasil.openFlows"
            ]
          },
          {
            "id": "open-chat",
            "title": "Open the Chat Panel",
            "description": "Stream from your local AI fleet right in your editor.",
            "media": {
              "markdown": "media/walkthrough/open-chat.md"
            },
            "completionEvents": [
              "onCommand:yggdrasil.openChat"
            ]
          }
        ]
      }
    ],
    "commands": [
      {
        "command": "yggdrasil.openFlows",
        "title": "Yggdrasil: Open Flows Explorer",
        "icon": "$(symbol-structure)"
      },
      {
        "command": "yggdrasil.refreshFlows",
        "title": "Yggdrasil: Refresh Flows",
        "icon": "$(refresh)"
      },
      {
        "command": "yggdrasil.openSettings",
        "title": "Yggdrasil: Open Settings",
        "icon": "$(settings-gear)"
      },
      {
        "command": "yggdrasil.openChat",
        "title": "Yggdrasil: Open Chat",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "yggdrasil.refreshModels",
        "title": "Yggdrasil: Refresh Models",
        "icon": "$(refresh)"
      },
      {
        "command": "yggdrasil.useModelInChat",
        "title": "Yggdrasil: Use Model in Chat"
      },
      {
        "command": "yggdrasil.openDashboard",
        "title": "Yggdrasil: Open Memory Dashboard"
      },
      {
        "command": "yggdrasil.showLog",
        "title": "Yggdrasil: Show Memory Log"
      },
      {
        "command": "yggdrasil.toggleNotifications",
        "title": "Yggdrasil: Toggle Notifications"
      },
      {
        "command": "yggdrasil.reinstallHooks",
        "title": "Yggdrasil: Reinstall Hooks"
      },
      {
        "command": "yggdrasil.checkForUpdates",
        "title": "Yggdrasil: Check for Updates"
      },
      {
        "command": "yggdrasil.chat.explainSelection",
        "title": "Yggdrasil: Explain Selection"
      },
      {
        "command": "yggdrasil.chat.askAboutFile",
        "title": "Yggdrasil: Ask About This File"
      },
      {
        "command": "yggdrasil.chat.editWithModel",
        "title": "Yggdrasil: Edit Selection With Model…"
      },
      {
        "command": "yggdrasil.attachFile",
        "title": "Yggdrasil: Attach File to Chat"
      },
      {
        "command": "yggdrasil.pickFile",
        "title": "Yggdrasil: Pick File to Attach"
      },
      {
        "command": "yggdrasil.previewEdit",
        "title": "Yggdrasil: Preview and Apply Edit"
      },
      {
        "command": "yggdrasil.voice.toggle",
        "title": "Yggdrasil: Toggle Voice Push-to-Talk"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "yggdrasil.refreshFlows",
          "when": "view == yggdrasil.flowsTree",
          "group": "navigation"
        },
        {
          "command": "yggdrasil.openFlows",
          "when": "view == yggdrasil.flowsTree",
          "group": "navigation"
        },
        {
          "command": "yggdrasil.openChat",
          "when": "view == yggdrasil.flowsTree",
          "group": "navigation@1"
        },
        {
          "command": "yggdrasil.openSettings",
          "when": "view == yggdrasil.flowsTree",
          "group": "navigation@2"
        },
        {
          "command": "yggdrasil.refreshModels",
          "when": "view == yggdrasil.modelsTree",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "yggdrasil.chat.explainSelection",
          "when": "editorHasSelection",
          "group": "yggdrasil@1"
        },
        {
          "command": "yggdrasil.chat.editWithModel",
          "when": "editorHasSelection",
          "group": "yggdrasil@2"
        },
        {
          "command": "yggdrasil.chat.askAboutFile",
          "group": "yggdrasil@3"
        }
      ],
      "commandPalette": [
        {
          "command": "yggdrasil.useModelInChat",
          "when": "false"
        }
      ]
    },
    "keybindings": [
      {
        "command": "yggdrasil.openDashboard",
        "key": "ctrl+shift+m",
        "when": "!terminalFocus"
      },
      {
        "command": "yggdrasil.openFlows",
        "key": "ctrl+shift+y",
        "when": "!terminalFocus"
      },
      {
        "command": "yggdrasil.openChat",
        "key": "ctrl+shift+i",
        "when": "!terminalFocus"
      },
      {
        "command": "yggdrasil.chat.explainSelection",
        "key": "ctrl+shift+e",
        "when": "editorHasSelection && !terminalFocus"
      },
      {
        "command": "yggdrasil.pickFile",
        "key": "ctrl+shift+@",
        "mac": "cmd+shift+@",
        "when": "!terminalFocus"
      },
      {
        "command": "yggdrasil.voice.toggle",
        "key": "ctrl+shift+space",
        "mac": "cmd+shift+space",
        "when": "webviewFocus && yggdrasil.chatVisible"
      }
    ],
    "configuration": {
      "title": "Yggdrasil",
      "properties": {
        "yggdrasil.eventsFile": {
          "type": "string",
          "default": "/tmp/ygg-hooks/memory-events.jsonl",
          "description": "Path to the JSONL event file written by ygg-memory.sh hooks"
        },
        "yggdrasil.notifications.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show toast notifications for memory operations"
        },
        "yggdrasil.notifications.sound": {
          "type": "boolean",
          "default": false,
          "description": "Play audio cue on memory store"
        },
        "yggdrasil.notifications.events": {
          "type": "array",
          "default": [
            "ingest",
            "error"
          ],
          "items": {
            "type": "string",
            "enum": [
              "init",
              "recall",
              "ingest",
              "sleep",
              "error",
              "sidecar",
              "error_recall",
              "update"
            ]
          },
          "description": "Which event types trigger notifications"
        },
        "yggdrasil.odinUrl": {
          "type": "string",
          "default": "http://localhost:8080",
          "description": "Odin router URL — chat completions, model list, flow CRUD"
        },
        "yggdrasil.mimirUrl": {
          "type": "string",
          "default": "http://localhost:9090",
          "description": "Mimir memory service URL"
        },
        "yggdrasil.huginUrl": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Hugin Ollama URL (reviewer + vision node)"
        },
        "yggdrasil.giteaUrl": {
          "type": "string",
          "default": "http://localhost:3000",
          "description": "Gitea server URL for auto-updates (set to your homelab Gitea instance)"
        },
        "yggdrasil.giteaRepo": {
          "type": "string",
          "default": "you/Yggdrasil",
          "description": "Gitea repo (owner/name) for release downloads"
        },
        "yggdrasil.githubRepo": {
          "type": "string",
          "default": "",
          "description": "GitHub repo (owner/name) for release downloads. Only used when yggdrasil.autoUpdate.provider = github."
        },
        "yggdrasil.autoUpdate.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Automatically check for extension updates once per hour"
        },
        "yggdrasil.autoUpdate.provider": {
          "type": "string",
          "enum": [
            "gitea",
            "github"
          ],
          "default": "gitea",
          "description": "Release host to check. Token lives in Settings → Secrets (giteaToken or githubToken)."
        },
        "yggdrasil.hooks.managed": {
          "type": "boolean",
          "default": true,
          "description": "Automatically manage Claude Code hooks in ~/.claude/settings.json"
        },
        "yggdrasil.hooks.writeMode": {
          "type": "string",
          "enum": [
            "replace",
            "merge"
          ],
          "default": "merge",
          "description": "How to handle existing hooks in ~/.claude/settings.json. 'merge' keeps your non-Yggdrasil hooks and appends ours (recommended). 'replace' overwrites the hooks tree with only Yggdrasil entries (pre-062 behaviour)."
        },
        "yggdrasil.chat.theme": {
          "type": "string",
          "enum": [
            "classic",
            "pipboy-green",
            "bbs-cyan"
          ],
          "default": "classic",
          "description": "Chat panel theme. 'classic' = stock dark; 'pipboy-green' = Fallout Pip-Boy phosphor; 'bbs-cyan' = 1980s BBS terminal."
        },
        "yggdrasil.chat.crtEffects": {
          "type": "boolean",
          "default": false,
          "description": "Overlay scanlines, sweep line, edge vignette, and subtle flicker on the chat panel. Pairs with the retro themes."
        },
        "yggdrasil.chat.font": {
          "type": "string",
          "enum": [
            "system",
            "vt323",
            "jetbrains-mono"
          ],
          "default": "system",
          "description": "Font family for the chat panel. 'vt323' = bundled retro pixel font; 'jetbrains-mono' = developer monospace; 'system' = VS Code default."
        },
        "yggdrasil.chat.autoInjectActiveEditor": {
          "type": "boolean",
          "default": true,
          "description": "Automatically send the active editor filename and language to the chat panel when you switch files."
        },
        "yggdrasil.voice.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable voice push-to-talk in the chat panel. Requires Odin voice WebSocket endpoint."
        },
        "yggdrasil.voice.pushToTalkKey": {
          "type": "string",
          "default": "ctrl+shift+space",
          "description": "Keyboard shortcut to activate voice push-to-talk while the chat panel is focused."
        },
        "yggdrasil.voice.ttsPlayback": {
          "type": "boolean",
          "default": true,
          "description": "Play back TTS audio responses from the voice endpoint when voice mode is active."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "package": "npx @vscode/vsce package --no-dependencies"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0"
  }
}
