[Unit]
Description=Yggdrasil Qwen2.5-Omni Voice Server (ROCm eGPU)
After=network.target

[Service]
Type=simple
User=jhernandez
WorkingDirectory=/opt/yggdrasil/deploy/qwen-omni
ExecStart=/opt/yggdrasil/deploy/qwen-omni/.venv/bin/python3 server.py --port 9098
Restart=on-failure
RestartSec=30
TimeoutStartSec=600
Environment=PYTHONUNBUFFERED=1
Environment=ROCR_VISIBLE_DEVICES=0
Environment=TORCH_ROCM_AOTRITON_ENABLE_EXPERIMENTAL=1

[Install]
WantedBy=multi-user.target
